#!/usr/bin/env bash
# claude-packs — install Claude Code skill/agent bundles into a project or user config.
#
# Pure bash: no Node, no npm, no runtime dependencies. Works on bash 3.2 (macOS) and up.
# Uses jq when available for manifest parsing, with an awk/sed fallback when it isn't.
set -euo pipefail

# --- locate the registry -------------------------------------------------------
# When installed via install.sh the launcher exports CLAUDE_PACKS_HOME. Running from a
# clone, fall back to the repo root relative to this script.
if [ -n "${CLAUDE_PACKS_HOME:-}" ]; then
  PKG_ROOT="$CLAUDE_PACKS_HOME"
else
  PKG_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi
BUNDLES_DIR="${PKG_ROOT}/bundles"
RECEIPT=".claude-packs"   # per-target install receipt (TSV: bundle version kind item)

if [ -n "${CLAUDE_PACKS_HOME:-}" ] || [ -n "${CLAUDE_PACKS_LAUNCHER:-}" ]; then
  IS_MANAGED=1
else
  IS_MANAGED=0
fi

CLI_VERSION="$(cat "${PKG_ROOT}/VERSION" 2>/dev/null || echo '0.0.0')"

# --- output --------------------------------------------------------------------
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  BOLD=$'\033[1m'; DIM=$'\033[2m'; RED=$'\033[31m'; GREEN=$'\033[32m'
  YELLOW=$'\033[33m'; CYAN=$'\033[36m'; RESET=$'\033[0m'
else
  BOLD=''; DIM=''; RED=''; GREEN=''; YELLOW=''; CYAN=''; RESET=''
fi

say()  { printf '%s\n' "$*"; }
die()  { printf '%serror:%s %s\n' "$RED" "$RESET" "$*" >&2; exit 1; }
warn() { printf '%swarning:%s %s\n' "$YELLOW" "$RESET" "$*" >&2; }

confirm() { # $1=question -> 0 if yes
  local q="$1" ans
  [ -e /dev/tty ] || return 1
  { printf '%s [y/N] ' "$q" > /dev/tty; } 2>/dev/null || return 1
  { read -r ans < /dev/tty; } 2>/dev/null || return 1
  case "$ans" in y|Y|yes|YES) return 0 ;; *) return 1 ;; esac
}

# --- manifest parsing ----------------------------------------------------------
have_jq() { command -v jq >/dev/null 2>&1; }

manifest_scalar() { # $1=manifest $2=key
  if have_jq; then
    jq -r --arg k "$2" '.[$k] // empty' "$1" 2>/dev/null || true
  else
    # constrained fallback: one "key": "value" per line, no embedded quotes
    sed -n 's/.*"'"$2"'"[[:space:]]*:[[:space:]]*"\(.*\)".*/\1/p' "$1" | head -n1
  fi
}

manifest_array() { # $1=manifest $2=key -> one item per line
  if have_jq; then
    jq -r --arg k "$2" '(.[$k] // [])[]' "$1" 2>/dev/null || true
  else
    awk -v key="\"$2\"" '
      index($0, key) && index($0, ":") { grab = 1 }
      grab { buf = buf $0; if (index($0, "]")) grab = 0 }
      END {
        sub(/.*\[/, "", buf); sub(/\].*/, "", buf)
        n = split(buf, a, ",")
        for (i = 1; i <= n; i++) { gsub(/[[:space:]"]/, "", a[i]); if (a[i] != "") print a[i] }
      }' "$1"
  fi
}

list_bundle_names() {
  [ -d "$BUNDLES_DIR" ] || return 0
  local d
  for d in "$BUNDLES_DIR"/*/; do
    [ -f "${d}bundle.json" ] || continue
    basename "$d"
  done
}

bundle_manifest() { # $1=name
  local m="${BUNDLES_DIR}/$1/bundle.json"
  [ -f "$m" ] || die "unknown bundle \"$1\". Run \"claude-packs list\" to see what's available."
  printf '%s\n' "$m"
}

bundle_version() { # $1=manifest
  local v; v="$(manifest_scalar "$1" version)"
  [ -n "$v" ] || v="0.0.0"
  printf '%s\n' "$v"
}

bundle_item_count() { # $1=manifest -> total skills + agents the bundle ships
  local ns na
  ns="$(manifest_array "$1" skills | grep -c . || true)"
  na="$(manifest_array "$1" agents | grep -c . || true)"
  printf '%s\n' "$(( ns + na ))"
}

# Split a "bundle" or "bundle:item1,item2" argument into $PB_NAME and $PB_FILTER
# (a newline-separated list of item names; empty means "the whole bundle").
parse_bundle_arg() { # $1=arg
  local arg="$1" items
  case "$arg" in
    *:*)
      PB_NAME="${arg%%:*}"
      items="${arg#*:}"
      PB_FILTER="$(printf '%s' "$items" | tr ',' '\n' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//' | grep -v '^$' || true)"
      ;;
    *)
      PB_NAME="$arg"
      PB_FILTER=''
      ;;
  esac
}

# --- receipt (install tracking) -------------------------------------------------
# Format: one TAB-separated line per installed item -> bundle<TAB>version<TAB>kind<TAB>item
receipt_file() { printf '%s\n' "${1}/${RECEIPT}"; }

receipt_version() { # $1=target $2=bundle
  local f; f="$(receipt_file "$1")"
  [ -f "$f" ] || return 0
  awk -F'\t' -v b="$2" '$1 == b { print $2; exit }' "$f"
}

receipt_items() { # $1=target $2=bundle $3=kind
  local f; f="$(receipt_file "$1")"
  [ -f "$f" ] || return 0
  awk -F'\t' -v b="$2" -v k="$3" '$1 == b && $3 == k { print $4 }' "$f"
}

receipt_owns() { # $1=target $2=bundle $3=kind $4=item
  local f; f="$(receipt_file "$1")"
  [ -f "$f" ] || return 1
  awk -F'\t' -v b="$2" -v k="$3" -v i="$4" \
    'BEGIN { rc = 1 } $1 == b && $3 == k && $4 == i { rc = 0 } END { exit rc }' "$f"
}

receipt_bundles() { # $1=target
  local f; f="$(receipt_file "$1")"
  [ -f "$f" ] || return 0
  awk -F'\t' '!/^#/ && NF { print $1 }' "$f" | sort -u
}

receipt_drop() { # $1=target $2=bundle
  local f tmp; f="$(receipt_file "$1")"
  [ -f "$f" ] || return 0
  tmp="${f}.tmp.$$"
  awk -F'\t' -v b="$2" '$1 != b' "$f" > "$tmp" && mv "$tmp" "$f"
}

receipt_add() { # $1=target $2=bundle $3=version $4=kind $5=item
  local f; f="$(receipt_file "$1")"
  mkdir -p "$1"
  if [ ! -f "$f" ]; then
    printf '# claude-packs install receipt — tracks what this tool installed. Do not edit.\n' > "$f"
    printf '# bundle\tversion\tkind\titem\n' >> "$f"
  fi
  printf '%s\t%s\t%s\t%s\n' "$2" "$3" "$4" "$5" >> "$f"
}

receipt_remove_item() { # $1=target $2=bundle $3=kind $4=item — drop one tracked line
  local f tmp; f="$(receipt_file "$1")"
  [ -f "$f" ] || return 0
  tmp="${f}.tmp.$$"
  awk -F'\t' -v b="$2" -v k="$3" -v i="$4" \
    '!($1 == b && $3 == k && $4 == i)' "$f" > "$tmp" && mv "$tmp" "$f"
}

# Per-bundle install mode: "full" (whole bundle — update auto-adds new items) or
# "select" (a chosen subset — update only refreshes those). Stored as a reserved
# "_mode" line so the item-listing helpers (which filter on kind) ignore it.
# Legacy receipts written before this feature have no marker; readers treat the
# empty result as "full", preserving the original whole-bundle behavior.
receipt_mode() { # $1=target $2=bundle -> full | select | ""
  local f; f="$(receipt_file "$1")"
  [ -f "$f" ] || return 0
  awk -F'\t' -v b="$2" '$1 == b && $3 == "_mode" { print $4; exit }' "$f"
}

receipt_set_mode() { # $1=target $2=bundle $3=version $4=mode
  local f tmp; f="$(receipt_file "$1")"
  if [ -f "$f" ]; then
    tmp="${f}.tmp.$$"
    awk -F'\t' -v b="$2" '!($1 == b && $3 == "_mode")' "$f" > "$tmp" && mv "$tmp" "$f"
  fi
  receipt_add "$1" "$2" "$3" _mode "$4"
}

# Count of items (skills + agents) the receipt tracks for a bundle.
receipt_item_count() { # $1=target $2=bundle
  local ns na
  ns="$(receipt_items "$1" "$2" skill | grep -c . || true)"
  na="$(receipt_items "$1" "$2" agent | grep -c . || true)"
  printf '%s\n' "$(( ns + na ))"
}

# --- target resolution ----------------------------------------------------------
resolve_target() {
  if [ -n "${OPT_PROJECT+x}" ]; then
    local dir="${OPT_PROJECT:-$PWD}"
    [ -d "$dir" ] || die "no such directory: $dir"
    printf '%s\n' "$(cd "$dir" && pwd)/.claude"
  else
    printf '%s\n' "${HOME}/.claude"
  fi
}

pretty_target() {
  if [ "$1" = "${HOME}/.claude" ]; then
    printf '%s\n' "~/.claude (user)"
  else
    printf '%s\n' "$(printf '%s' "$1" | sed "s|^${HOME}|~|")"
  fi
}

# --- commands -------------------------------------------------------------------
cmd_list() {
  local names target
  names="$(list_bundle_names)"
  [ -n "$names" ] || { say "No bundles found in ${BUNDLES_DIR}."; return 0; }
  target="$(resolve_target)"
  printf '\n%sAvailable bundles%s%s  (installed status vs %s)%s\n\n' \
    "$BOLD" "$RESET" "$DIM" "$(pretty_target "$target")" "$RESET"

  local name m ver title tags nskills nagents ntotal ninst inst badge behind
  while IFS= read -r name; do
    [ -n "$name" ] || continue
    m="${BUNDLES_DIR}/${name}/bundle.json"
    ver="$(bundle_version "$m")"
    title="$(manifest_scalar "$m" title)"
    tags="$(manifest_array "$m" tags | paste -sd, - | sed 's/,/, /g')"
    nskills="$(manifest_array "$m" skills | grep -c . || true)"
    nagents="$(manifest_array "$m" agents | grep -c . || true)"
    ntotal=$(( nskills + nagents ))
    ninst="$(receipt_item_count "$target" "$name")"
    inst="$(receipt_version "$target" "$name")"
    behind=''
    [ -n "$inst" ] && [ "$inst" != "$ver" ] && behind="${DIM} (${inst} → ${ver} available)${RESET}"
    if [ "$ninst" -eq 0 ]; then
      badge="${DIM}not installed${RESET}"
    elif [ "$ninst" -lt "$ntotal" ]; then
      badge="${YELLOW}◑ partial${RESET}${DIM} (${ninst}/${ntotal} items)${RESET}${behind}"
    else
      badge="${GREEN}✓ installed${RESET}${behind}"
    fi
    printf '  %s%s%s%s %sv%s%s  %s\n' "$BOLD" "$CYAN" "$name" "$RESET" "$DIM" "$ver" "$RESET" "$badge"
    [ -n "$title" ] && printf '    %s\n' "$title"
    printf '%s    %s skills, %s agents%s' "$DIM" "$nskills" "$nagents" "$RESET"
    [ -n "$tags" ] && printf '%s  ·  %s%s' "$DIM" "$tags" "$RESET"
    printf '\n'
  done <<EOF
$names
EOF
  printf '\n%sInstall with:%s claude-packs install <bundle>[:item,...] [--user | --project [dir]]\n' "$DIM" "$RESET"
  printf '%s             %s or run %sclaude-packs tui%s to pick items interactively.\n\n' "$DIM" "$RESET" "$CYAN" "$RESET"
}

cmd_info() {
  [ "${#BUNDLE_ARGS[@]}" -gt 0 ] || die "usage: claude-packs info <bundle>"
  local name m ver title desc tags
  name="${BUNDLE_ARGS[0]}"
  m="$(bundle_manifest "$name")"
  ver="$(bundle_version "$m")"
  title="$(manifest_scalar "$m" title)"
  desc="$(manifest_scalar "$m" description)"
  tags="$(manifest_array "$m" tags | paste -sd, - | sed 's/,/, /g')"

  printf '\n%s%s%s%s  v%s%s\n' "$BOLD" "$CYAN" "$name" "$DIM" "$ver" "$RESET"
  [ -n "$title" ] && printf '%s%s%s\n' "$BOLD" "$title" "$RESET"
  [ -n "$desc" ] && { printf '\n'; printf '%s\n' "$desc" | fold -s -w 80; }
  [ -n "$tags" ] && printf '\n%stags:%s %s\n' "$DIM" "$RESET" "$tags"

  # Guides live in the bundle and are not installed — point at them explicitly.
  local guide guide_path
  guide="$(manifest_scalar "$m" guide)"
  if [ -n "$guide" ]; then
    guide_path="${BUNDLES_DIR}/${name}/${guide}"
    if [ -f "$guide_path" ]; then
      printf '\n%sguide:%s %s\n' "$DIM" "$RESET" "$guide_path"
    fi
  fi

  local s a
  printf '\n%sSkills%s\n' "$BOLD" "$RESET"
  while IFS= read -r s; do
    [ -n "$s" ] || continue
    printf '  %s•%s %s\n' "$GREEN" "$RESET" "$s"
  done <<EOF
$(manifest_array "$m" skills)
EOF
  printf '\n%sAgents%s\n' "$BOLD" "$RESET"
  while IFS= read -r a; do
    [ -n "$a" ] || continue
    printf '  %s•%s %s\n' "$GREEN" "$RESET" "$a"
  done <<EOF
$(manifest_array "$m" agents)
EOF
  printf '\n'
}

# $1=bundle name  $2=target  $3=filter (newline list of item names; empty = whole bundle)
#
# Additive by design: only the items that pass the filter are (re)installed, and
# each gets its receipt line upserted while any other tracked items are left in
# place. This is what lets a user grow a selective install one skill at a time.
install_one() {
  local name="$1" target="$2" filter="${3-}" m ver bdir src dest s a old want
  local partial=0; [ -n "$filter" ] && partial=1
  m="$(bundle_manifest "$name")"
  ver="$(bundle_version "$m")"
  bdir="${BUNDLES_DIR}/${name}"

  if [ "$partial" -eq 1 ]; then
    printf '\n%sInstalling %s%s%s %sselected items%s%s v%s → %s%s\n' \
      "$BOLD" "$CYAN" "$name" "$RESET" "$DIM" "$RESET" "$BOLD" "$ver" "$(pretty_target "$target")" "$RESET"
  else
    printf '\n%sInstalling %s%s%s%s v%s → %s%s\n' \
      "$BOLD" "$CYAN" "$name" "$RESET" "$BOLD" "$ver" "$(pretty_target "$target")" "$RESET"
  fi

  mkdir -p "${target}/skills" "${target}/agents"

  # membership test against the filter — always true for a whole-bundle install
  in_filter() { [ "$partial" -eq 0 ] && return 0; printf '%s\n' "$filter" | grep -qxF -- "$1"; }

  # collect first, so a declined overwrite doesn't leave a half-written receipt.
  # $matched tracks every filter name we actually saw, to flag typos afterward.
  local ok_skills='' ok_agents='' matched=''

  while IFS= read -r s; do
    [ -n "$s" ] || continue
    in_filter "$s" || continue
    matched="${matched}${s}
"
    src="${bdir}/skills/${s}"
    dest="${target}/skills/${s}"
    if [ ! -d "$src" ]; then warn "skill \"$s\" missing from bundle, skipping"; continue; fi
    if [ -e "$dest" ] && [ "$OPT_FORCE" -ne 1 ] && ! receipt_owns "$target" "$name" skill "$s"; then
      if ! confirm "  ${dest} exists and is not tracked by claude-packs. Overwrite?"; then
        printf '  %s- skipped skill %s%s\n' "$DIM" "$s" "$RESET"; continue
      fi
    fi
    rm -rf "$dest"
    cp -R "$src" "$dest"
    ok_skills="${ok_skills}${s}
"
    printf '  %s+%s skill %s\n' "$GREEN" "$RESET" "$s"
  done <<EOF
$(manifest_array "$m" skills)
EOF

  while IFS= read -r a; do
    [ -n "$a" ] || continue
    in_filter "$a" || continue
    matched="${matched}${a}
"
    src="${bdir}/agents/${a}.md"
    dest="${target}/agents/${a}.md"
    if [ ! -f "$src" ]; then warn "agent \"$a\" missing from bundle, skipping"; continue; fi
    if [ -e "$dest" ] && [ "$OPT_FORCE" -ne 1 ] && ! receipt_owns "$target" "$name" agent "$a"; then
      if ! confirm "  ${dest} exists and is not tracked by claude-packs. Overwrite?"; then
        printf '  %s- skipped agent %s%s\n' "$DIM" "$a" "$RESET"; continue
      fi
    fi
    cp "$src" "$dest"
    ok_agents="${ok_agents}${a}
"
    printf '  %s+%s agent %s\n' "$GREEN" "$RESET" "$a"
  done <<EOF
$(manifest_array "$m" agents)
EOF

  # flag any requested item name that matched no skill or agent in this bundle
  if [ "$partial" -eq 1 ]; then
    while IFS= read -r want; do
      [ -n "$want" ] || continue
      printf '%s\n' "$matched" | grep -qxF -- "$want" \
        || warn "\"$want\" is not a skill or agent in bundle \"$name\" — skipped"
    done <<EOF
$filter
EOF
  fi

  # prune true orphans: items the receipt still tracks that this bundle no longer
  # ships. Safe in both modes — it only ever removes items absent from the manifest
  # entirely, never a manifest item the user simply chose not to install.
  while IFS= read -r old; do
    [ -n "$old" ] || continue
    if ! manifest_array "$m" skills | grep -qx "$old"; then
      rm -rf "${target}/skills/${old}"
      receipt_remove_item "$target" "$name" skill "$old"
      printf '  %s-%s skill %s %s(no longer in bundle)%s\n' "$RED" "$RESET" "$old" "$DIM" "$RESET"
    fi
  done <<EOF
$(receipt_items "$target" "$name" skill)
EOF
  while IFS= read -r old; do
    [ -n "$old" ] || continue
    if ! manifest_array "$m" agents | grep -qx "$old"; then
      rm -f "${target}/agents/${old}.md"
      receipt_remove_item "$target" "$name" agent "$old"
      printf '  %s-%s agent %s %s(no longer in bundle)%s\n' "$RED" "$RESET" "$old" "$DIM" "$RESET"
    fi
  done <<EOF
$(receipt_items "$target" "$name" agent)
EOF

  # upsert the receipt line for each item we (re)installed, keeping every other
  # tracked item's line untouched
  while IFS= read -r s; do
    [ -n "$s" ] || continue
    receipt_remove_item "$target" "$name" skill "$s"
    receipt_add "$target" "$name" "$ver" skill "$s"
  done <<EOF
$ok_skills
EOF
  while IFS= read -r a; do
    [ -n "$a" ] || continue
    receipt_remove_item "$target" "$name" agent "$a"
    receipt_add "$target" "$name" "$ver" agent "$a"
  done <<EOF
$ok_agents
EOF

  # record whether the target now holds the whole bundle or a subset, so `update`
  # knows to auto-add newly-shipped items (full) or refresh only the chosen ones.
  local tracked_n manifest_n
  tracked_n="$(receipt_item_count "$target" "$name")"
  manifest_n="$(bundle_item_count "$m")"
  if [ "$tracked_n" -eq 0 ]; then
    # nothing ended up tracked (e.g. every requested item name was a typo, or all
    # overwrites were declined) — leave no phantom receipt entry behind
    receipt_drop "$target" "$name"
  elif [ "$manifest_n" -gt 0 ] && [ "$tracked_n" -ge "$manifest_n" ]; then
    receipt_set_mode "$target" "$name" "$ver" full
  else
    receipt_set_mode "$target" "$name" "$ver" select
  fi
}

cmd_install() {
  [ "${#BUNDLE_ARGS[@]}" -gt 0 ] || \
    die "usage: claude-packs install <bundle[:item,...]...> [--user | --project [dir]] [--force]"
  local target arg
  target="$(resolve_target)"
  for arg in "${BUNDLE_ARGS[@]}"; do
    parse_bundle_arg "$arg"
    install_one "$PB_NAME" "$target" "$PB_FILTER"
  done
  printf '\n%s✓ Done.%s Restart Claude Code — skills and agents load at session start.\n\n' \
    "$GREEN" "$RESET"
}

cmd_uninstall() {
  [ "${#BUNDLE_ARGS[@]}" -gt 0 ] || \
    die "usage: claude-packs uninstall <bundle[:item,...]...> [--user | --project [dir]]"
  local target arg name p item changed=0 partial
  target="$(resolve_target)"
  for arg in "${BUNDLE_ARGS[@]}"; do
    parse_bundle_arg "$arg"
    name="$PB_NAME"
    if [ -z "$(receipt_version "$target" "$name")" ]; then
      printf '  %s%s is not installed at %s%s\n' "$YELLOW" "$name" "$(pretty_target "$target")" "$RESET"
      continue
    fi
    partial=0; [ -n "$PB_FILTER" ] && partial=1

    if [ "$partial" -eq 1 ]; then
      # remove only the named items this bundle actually owns
      printf '\n%sRemoving %sselected items%s from %s%s%s at %s%s\n' \
        "$BOLD" "$DIM" "$RESET$BOLD" "$CYAN" "$name" "$RESET$BOLD" "$(pretty_target "$target")" "$RESET"
      local removed
      while IFS= read -r item; do
        [ -n "$item" ] || continue
        removed=0
        if receipt_owns "$target" "$name" skill "$item"; then
          rm -rf "${target}/skills/${item}"
          receipt_remove_item "$target" "$name" skill "$item"
          printf '  %s-%s skill %s\n' "$RED" "$RESET" "$item"; removed=1
        fi
        if receipt_owns "$target" "$name" agent "$item"; then
          rm -f "${target}/agents/${item}.md"
          receipt_remove_item "$target" "$name" agent "$item"
          printf '  %s-%s agent %s\n' "$RED" "$RESET" "$item"; removed=1
        fi
        [ "$removed" -eq 1 ] || warn "\"$item\" is not an installed item of \"$name\" — skipped"
      done <<EOF
$PB_FILTER
EOF
      # if the last item is gone, drop the bundle entirely; otherwise it is now a selection
      if [ "$(receipt_item_count "$target" "$name")" -eq 0 ]; then
        receipt_drop "$target" "$name"
      else
        receipt_set_mode "$target" "$name" "$(receipt_version "$target" "$name")" select
      fi
      changed=1
      continue
    fi

    # whole-bundle removal
    printf '\n%sRemoving %s%s%s%s from %s%s\n' \
      "$BOLD" "$CYAN" "$name" "$RESET" "$BOLD" "$(pretty_target "$target")" "$RESET"
    while IFS= read -r p; do
      [ -n "$p" ] || continue
      if [ -e "${target}/skills/${p}" ]; then
        rm -rf "${target}/skills/${p}"
        printf '  %s-%s skill %s\n' "$RED" "$RESET" "$p"
      fi
    done <<EOF
$(receipt_items "$target" "$name" skill)
EOF
    while IFS= read -r p; do
      [ -n "$p" ] || continue
      if [ -e "${target}/agents/${p}.md" ]; then
        rm -f "${target}/agents/${p}.md"
        printf '  %s-%s agent %s\n' "$RED" "$RESET" "$p"
      fi
    done <<EOF
$(receipt_items "$target" "$name" agent)
EOF
    receipt_drop "$target" "$name"
    changed=1
  done
  [ "$changed" -eq 1 ] && printf '\n%s✓ Uninstalled.%s\n\n' "$GREEN" "$RESET"
  return 0
}

cmd_update() {
  local target names arg
  target="$(resolve_target)"
  if [ "${#BUNDLE_ARGS[@]}" -gt 0 ]; then
    # accept "bundle" or "bundle:item,..."; update always follows how the bundle
    # was installed (full vs selection), so the item part is only used to name it
    names=''
    for arg in "${BUNDLE_ARGS[@]}"; do
      parse_bundle_arg "$arg"
      names="${names}${PB_NAME}
"
    done
  else
    names="$(receipt_bundles "$target")"
  fi
  if [ -z "$names" ]; then
    say "Nothing installed at $(pretty_target "$target")."
    return 0
  fi
  # Refresh the registry first so "update" means "latest", not "whatever was cloned
  # last time". Only for managed installs — never git-pull a contributor's dev clone.
  # Non-git managed installs (install.sh --local) get a note instead.
  if [ "$IS_MANAGED" -eq 1 ] && [ -d "${PKG_ROOT}/.git" ] && command -v git >/dev/null 2>&1; then
    printf '%sRefreshing registry (git pull) ...%s\n' "$DIM" "$RESET"
    git -C "$PKG_ROOT" pull --ff-only >/dev/null 2>&1 \
      || warn "could not refresh the registry (git pull failed) — updating from local content"
  elif [ -n "${CLAUDE_PACKS_DIST:-}" ]; then
    say "${DIM}bundle content ships inside the package — run \"claude-packs self-update\" to see how to get newer bundles${RESET}"
  elif [ "$IS_MANAGED" -eq 1 ]; then
    warn "registry is not a git checkout (installed with --local) — updating from local content only"
  fi
  printf '%sRe-installing latest bundle content over existing installs...%s\n' "$DIM" "$RESET"
  OPT_FORCE=1
  local name prev cur mode filter
  while IFS= read -r name; do
    [ -n "$name" ] || continue
    prev="$(receipt_version "$target" "$name")"
    mode="$(receipt_mode "$target" "$name")"
    if [ "$mode" = select ]; then
      # refresh only the items this target tracks — never re-expand a selection to
      # the whole bundle just because a newer version ships more
      filter="$(printf '%s\n%s\n' \
        "$(receipt_items "$target" "$name" skill)" \
        "$(receipt_items "$target" "$name" agent)" | grep -v '^$' || true)"
      install_one "$name" "$target" "$filter"
    else
      install_one "$name" "$target"
    fi
    cur="$(receipt_version "$target" "$name")"
    if [ -n "$prev" ] && [ -n "$cur" ] && [ "$prev" != "$cur" ]; then
      printf '  %s↑ %s v%s → v%s%s\n' "$GREEN" "$name" "$prev" "$cur" "$RESET"
    fi
  done <<EOF
$names
EOF
  printf '\n%s✓ Done.%s Restart Claude Code — skills and agents load at session start.\n\n' \
    "$GREEN" "$RESET"
}

cmd_installed() {
  local target names name ver ns na
  target="$(resolve_target)"
  names="$(receipt_bundles "$target")"
  if [ -z "$names" ]; then
    say "No bundles installed at $(pretty_target "$target")."
    return 0
  fi
  printf '\n%sInstalled at %s:%s\n\n' "$BOLD" "$(pretty_target "$target")" "$RESET"
  local sel
  while IFS= read -r name; do
    [ -n "$name" ] || continue
    ver="$(receipt_version "$target" "$name")"
    ns="$(receipt_items "$target" "$name" skill | grep -c . || true)"
    na="$(receipt_items "$target" "$name" agent | grep -c . || true)"
    if [ "$(receipt_mode "$target" "$name")" = select ]; then
      sel="${YELLOW}  ◑ selection${RESET}"
    else
      sel=''
    fi
    printf '  %s%s%s %sv%s%s  %s(%s skills, %s agents)%s%s\n' \
      "$CYAN" "$name" "$RESET" "$DIM" "$ver" "$RESET" "$DIM" "$ns" "$na" "$RESET" "$sel"
  done <<EOF
$names
EOF
  printf '\n'
}

INSTALLER_URL="https://raw.githubusercontent.com/St-Luciferr/claude-skills-pack/main/install.sh"

cmd_self_update() {
  local old_ver="$CLI_VERSION" new_ver
  # Package-manager installs (PyPI / npm) update through their own tooling — the
  # registry lives inside the installed package, so git/installer paths don't apply.
  if [ -n "${CLAUDE_PACKS_DIST:-}" ]; then
    case "$CLAUDE_PACKS_DIST" in
      pypi)
        say "This claude-packs (v${CLI_VERSION}) was installed from PyPI — update it with"
        say "the tool that installed it:"
        say "  uv tool upgrade claude-packs        # uv"
        say "  pipx upgrade claude-packs           # pipx"
        say "  pip install -U claude-packs         # pip"
        say ""
        say "(uvx claude-packs always runs the latest published version.)"
        ;;
      npm)
        say "This claude-packs (v${CLI_VERSION}) was installed from npm — update it with:"
        say "  npm update -g claude-skills-pack"
        say ""
        say "(npx claude-skills-pack@latest always runs the latest published version.)"
        ;;
      *)
        say "This claude-packs (v${CLI_VERSION}) came from a package manager (${CLAUDE_PACKS_DIST})."
        say "Update it through that package manager."
        ;;
    esac
    say "Then run: claude-packs update   # to push newer bundle content into your installs"
    return 0
  fi
  if [ ! -d "${PKG_ROOT}/.git" ]; then
    # --local installs have no git history — updating means re-running the installer,
    # which replaces the registry with a fresh git-backed clone.
    if [ "$IS_MANAGED" -eq 1 ] && command -v curl >/dev/null 2>&1; then
      say "Registry at ${PKG_ROOT} is not git-backed (installed with --local)."
      if [ "$OPT_FORCE" -ne 1 ] && ! confirm "Re-run the installer to switch to a git-backed install?"; then
        say "Aborted. Run manually:"
        say "  curl -fsSL ${INSTALLER_URL} | bash"
        return 0
      fi
      curl -fsSL "$INSTALLER_URL" | bash || die "installer failed."
      return 0
    fi
    die "can't self-update: ${PKG_ROOT} is not a git checkout.
Re-run the installer to update to the latest version:
  curl -fsSL ${INSTALLER_URL} | bash"
  fi
  command -v git >/dev/null 2>&1 || die "git is required for self-update."
  printf '%sUpdating claude-packs registry in %s ...%s\n' "$DIM" "$PKG_ROOT" "$RESET"
  git -C "$PKG_ROOT" pull --ff-only || die "git pull failed."
  new_ver="$(cat "${PKG_ROOT}/VERSION" 2>/dev/null || echo "$old_ver")"
  if [ "$new_ver" != "$old_ver" ]; then
    printf '\n%s✓ claude-packs updated%s %s(v%s → v%s)%s. Run %sclaude-packs update%s to push newer bundle content into your installs.\n\n' \
      "$GREEN" "$RESET" "$DIM" "$old_ver" "$new_ver" "$RESET" "$CYAN" "$RESET"
  else
    printf '\n%s✓ claude-packs is up to date%s %s(v%s)%s.\n\n' "$GREEN" "$RESET" "$DIM" "$new_ver" "$RESET"
  fi
}

cmd_self_uninstall() {
  if [ -n "${CLAUDE_PACKS_DIST:-}" ]; then
    case "$CLAUDE_PACKS_DIST" in
      pypi) die "installed from PyPI — remove with the tool that installed it:
  uv tool uninstall claude-packs   |   pipx uninstall claude-packs   |   pip uninstall claude-packs" ;;
      npm)  die "installed from npm — remove with:
  npm rm -g claude-skills-pack" ;;
      *)    die "installed via ${CLAUDE_PACKS_DIST} — remove it through that package manager." ;;
    esac
  fi
  if [ "$IS_MANAGED" -ne 1 ]; then
    die "self-uninstall only works for a device-installed CLI, not a dev clone.
This looks like a source checkout — nothing to remove."
  fi
  printf '\n%sThis removes the claude-packs CLI from your device:%s\n' "$BOLD" "$RESET"
  printf '  %s%s  (registry + bundles)%s\n' "$PKG_ROOT" "$DIM" "$RESET"
  [ -n "${CLAUDE_PACKS_LAUNCHER:-}" ] && \
    printf '  %s%s  (launcher on your PATH)%s\n' "$CLAUDE_PACKS_LAUNCHER" "$DIM" "$RESET"
  printf '%s\nBundles already installed into your projects / ~/.claude are NOT touched.%s\n' "$DIM" "$RESET"

  if [ "$OPT_FORCE" -ne 1 ] && ! confirm $'\nProceed?'; then
    say "Aborted."; return 0
  fi
  if [ -n "${CLAUDE_PACKS_LAUNCHER:-}" ] && [ -e "$CLAUDE_PACKS_LAUNCHER" ]; then
    rm -f "$CLAUDE_PACKS_LAUNCHER"
    printf '%s-%s %s\n' "$RED" "$RESET" "$CLAUDE_PACKS_LAUNCHER"
  fi
  # safety: only remove PKG_ROOT if it really is a managed registry
  if [ -f "${PKG_ROOT}/bin/claude-packs" ]; then
    rm -rf "$PKG_ROOT"
    printf '%s-%s %s\n' "$RED" "$RESET" "$PKG_ROOT"
  fi
  printf '\n%s✓ claude-packs removed.%s\n\n' "$GREEN" "$RESET"
}

# --- interactive TUI ------------------------------------------------------------
# A full-screen, keyboard- and mouse-driven menu for browsing and managing
# bundles. Pure ANSI + bash reads — no ncurses, no external TUI deps. Reuses the
# cmd_* functions so install/uninstall/update behave exactly like the CLI.
tui_mouse_on()  { printf '\033[?1000h\033[?1006h'; }    # SGR click/scroll reporting
tui_mouse_off() { printf '\033[?1000l\033[?1006l'; }
tui_enter_screen() { printf '\033[?1049h\033[?25l'; tui_mouse_on; }   # alt buf, hide cursor, mouse
tui_leave_screen() { tui_mouse_off; printf '\033[?25h\033[?1049l'; }  # restore everything

# Parse an SGR mouse report body "btn;col;row" (final char M=press, m=release)
# into MOUSE_BTN / MOUSE_X / MOUSE_Y / MOUSE_TYPE.
parse_mouse() { # $1="btn;col;row"  $2=M|m
  local s="$1" rest
  MOUSE_BTN="${s%%;*}"; rest="${s#*;}"
  MOUSE_X="${rest%%;*}"; MOUSE_Y="${rest##*;}"
  [ "$2" = M ] && MOUSE_TYPE=press || MOUSE_TYPE=release
  case "$MOUSE_BTN" in ''|*[!0-9]*) MOUSE_BTN=0 ;; esac
  case "$MOUSE_X"   in ''|*[!0-9]*) MOUSE_X=0 ;; esac
  case "$MOUSE_Y"   in ''|*[!0-9]*) MOUSE_Y=0 ;; esac
}

# Read one input event into $KEY. Normal keys come through verbatim; arrows as
# ESC[A/B/C/D; a mouse click/scroll sets KEY=mouse plus the MOUSE_* globals.
# Returns 1 on EOF.
read_key() {
  local a b ch seq
  KEY=''; MOUSE_TYPE=''
  IFS= read -rsn1 KEY </dev/tty 2>/dev/null || return 1
  [ "$KEY" = $'\033' ] || return 0
  # ESC: lone Escape, an arrow (ESC [ A), or a mouse report (ESC [ < …)
  IFS= read -rsn1 -t 1 a </dev/tty 2>/dev/null || { KEY=$'\033'; return 0; }
  if [ "$a" != '[' ]; then KEY=$'\033'"$a"; return 0; fi
  IFS= read -rsn1 -t 1 b </dev/tty 2>/dev/null || { KEY=$'\033['; return 0; }
  if [ "$b" = '<' ]; then
    seq=''
    while IFS= read -rsn1 -t 1 ch </dev/tty 2>/dev/null; do
      case "$ch" in M|m) break ;; esac
      seq="$seq$ch"
    done
    parse_mouse "$seq" "${ch:-M}"
    KEY='mouse'
    return 0
  fi
  KEY=$'\033['"$b"
  return 0
}

tui_target() {
  if [ "$TUI_TARGET_MODE" = project ]; then
    printf '%s/.claude\n' "$(cd "$TUI_PROJECT_DIR" 2>/dev/null && pwd || printf '%s' "$TUI_PROJECT_DIR")"
  else
    printf '%s/.claude\n' "$HOME"
  fi
}

# (re)load bundle rows into the parallel arrays the drawer reads.
tui_load() {
  NAMES=(); VERS=(); TITLES=(); INST=(); SEL=(); NINST=(); NTOTAL=()
  local target name m
  target="$(tui_target)"
  while IFS= read -r name; do
    [ -n "$name" ] || continue
    m="${BUNDLES_DIR}/${name}/bundle.json"
    NAMES[${#NAMES[@]}]="$name"
    VERS[${#VERS[@]}]="$(bundle_version "$m")"
    TITLES[${#TITLES[@]}]="$(manifest_scalar "$m" title)"
    INST[${#INST[@]}]="$(receipt_version "$target" "$name")"
    NINST[${#NINST[@]}]="$(receipt_item_count "$target" "$name")"
    NTOTAL[${#NTOTAL[@]}]="$(bundle_item_count "$m")"
    SEL[${#SEL[@]}]=0
  done < <(list_bundle_names)
  local n=${#NAMES[@]}
  if [ "$n" -eq 0 ]; then cursor=0
  elif [ "$cursor" -ge "$n" ]; then cursor=$((n - 1)); fi
  [ "$cursor" -ge 0 ] || cursor=0
  return 0
}

# load the individual skills/agents of $CUR_BUNDLE into the item-view arrays.
# $1 = initial selection: "all" ticks every item (install-everything default),
# anything else leaves them unticked. Reloading after an action preserves nothing
# on purpose — the freshly-read install status is what the checkboxes reset to.
tui_load_items() {
  local presel="${1:-none}"
  IKIND=(); INAME=(); IINST=(); ISEL=()
  local target m s a init=0
  [ "$presel" = all ] && init=1
  target="$(tui_target)"
  m="${BUNDLES_DIR}/${CUR_BUNDLE}/bundle.json"
  while IFS= read -r s; do
    [ -n "$s" ] || continue
    IKIND[${#IKIND[@]}]=skill
    INAME[${#INAME[@]}]="$s"
    if receipt_owns "$target" "$CUR_BUNDLE" skill "$s"; then IINST[${#IINST[@]}]=1; else IINST[${#IINST[@]}]=0; fi
    ISEL[${#ISEL[@]}]=$init
  done <<EOF
$(manifest_array "$m" skills)
EOF
  while IFS= read -r a; do
    [ -n "$a" ] || continue
    IKIND[${#IKIND[@]}]=agent
    INAME[${#INAME[@]}]="$a"
    if receipt_owns "$target" "$CUR_BUNDLE" agent "$a"; then IINST[${#IINST[@]}]=1; else IINST[${#IINST[@]}]=0; fi
    ISEL[${#ISEL[@]}]=$init
  done <<EOF
$(manifest_array "$m" agents)
EOF
  local n=${#INAME[@]}
  if [ "$n" -eq 0 ]; then icursor=0
  elif [ "$icursor" -ge "$n" ]; then icursor=$((n - 1)); fi
  [ "$icursor" -ge 0 ] || icursor=0
  return 0
}

tui_draw() {
  local target ptarget i rowcur marker name ver inst ninst ntotal badge behind row
  target="$(tui_target)"; ptarget="$(pretty_target "$target")"
  CLICK_ITEM=()                       # terminal-row → bundle index, for mouse clicks
  printf '\033[H\033[2J'
  printf '  %s%sclaude-packs%s %sv%s%s  %s— interactive%s\n' \
    "$BOLD" "$CYAN" "$RESET" "$DIM" "$CLI_VERSION" "$RESET" "$DIM" "$RESET"
  printf '  %sTarget%s %s   %s(press t to change)%s\n\n' "$DIM" "$RESET" "$ptarget" "$DIM" "$RESET"
  row=3                               # rows 1-2 header, row 3 blank; items start at 4

  for i in "${!NAMES[@]}"; do
    name="${NAMES[$i]}"; ver="${VERS[$i]}"; inst="${INST[$i]}"
    ninst="${NINST[$i]}"; ntotal="${NTOTAL[$i]}"
    if [ "$i" -eq "$cursor" ]; then rowcur="${CYAN}❯${RESET}"; else rowcur=' '; fi
    if [ "${SEL[$i]}" = 1 ]; then marker="${GREEN}◉${RESET}"; else marker="${DIM}◯${RESET}"; fi
    behind=''
    [ -n "$inst" ] && [ "$inst" != "$ver" ] && behind="${DIM} (${inst} → ${ver})${RESET}"
    if [ "$ninst" -eq 0 ]; then
      badge="${DIM}not installed${RESET}"
    elif [ "$ninst" -lt "$ntotal" ]; then
      badge="${YELLOW}◑ partial${RESET}${DIM} (${ninst}/${ntotal})${RESET}${behind}"
    else
      badge="${GREEN}✓ installed${RESET}${behind}"
    fi
    row=$((row + 1)); CLICK_ITEM[$row]=$i
    printf ' %s %s %s%s%-20s%s %sv%s%s  %s\n' \
      "$rowcur" "$marker" "$BOLD" "$CYAN" "$name" "$RESET" "$DIM" "$ver" "$RESET" "$badge"
    if [ -n "${TITLES[$i]}" ]; then
      row=$((row + 1)); CLICK_ITEM[$row]=$i
      printf '       %s%s%s\n' "$DIM" "${TITLES[$i]}" "$RESET"
    fi
  done

  printf '\n  %s↑/↓%s move   %sspace/enter%s select   %sa%s all   %s→ or click%s open & pick skills\n' \
    "$BOLD" "$RESET" "$BOLD" "$RESET" "$BOLD" "$RESET" "$BOLD" "$RESET"
  printf '  %si%s install   %sx%s uninstall   %su%s update   %st%s target   %sq%s quit\n' \
    "$GREEN" "$RESET" "$RED" "$RESET" "$CYAN" "$RESET" "$BOLD" "$RESET" "$BOLD" "$RESET"
  [ -n "$TUI_MSG" ] && printf '\n  %s\n' "$TUI_MSG"
  return 0   # never let a false trailing test trip `set -e` from the draw loop
}

# item drill-in view: the individual skills and agents of $CUR_BUNDLE
tui_draw_items() {
  local target ptarget i rowcur marker prevkind='' name inst tag nsel=0 row bi bu bb c
  target="$(tui_target)"; ptarget="$(pretty_target "$target")"
  for i in "${!INAME[@]}"; do [ "${ISEL[$i]}" = 1 ] && nsel=$((nsel + 1)); done
  CLICK_ITEM=()
  printf '\033[H\033[2J'
  printf '  %s%sclaude-packs%s %sv%s%s  %s— %s%s\n' \
    "$BOLD" "$CYAN" "$RESET" "$DIM" "$CLI_VERSION" "$RESET" "$BOLD" "$CUR_BUNDLE" "$RESET"
  printf '  %sTarget%s %s\n' "$DIM" "$RESET" "$ptarget"
  printf '  %sTick items with space/enter or a click, then Install%s   %s(%d selected)%s\n' \
    "$DIM" "$RESET" "$DIM" "$nsel" "$RESET"
  row=3

  for i in "${!INAME[@]}"; do
    if [ "${IKIND[$i]}" != "$prevkind" ]; then
      prevkind="${IKIND[$i]}"
      if [ "$prevkind" = skill ]; then printf '\n  %sSkills%s\n' "$BOLD" "$RESET"
      else printf '\n  %sAgents%s\n' "$BOLD" "$RESET"; fi
      row=$((row + 2))
    fi
    name="${INAME[$i]}"; inst="${IINST[$i]}"
    if [ "$i" -eq "$icursor" ]; then rowcur="${CYAN}❯${RESET}"; else rowcur=' '; fi
    if [ "${ISEL[$i]}" = 1 ]; then marker="${GREEN}◉${RESET}"; else marker="${DIM}◯${RESET}"; fi
    if [ "$inst" = 1 ]; then tag="${GREEN}✓ installed${RESET}"; else tag="${DIM}not installed${RESET}"; fi
    row=$((row + 1)); CLICK_ITEM[$row]=$i
    printf ' %s %s %s%-30s%s %s\n' "$rowcur" "$marker" "$CYAN" "$name" "$RESET" "$tag"
  done

  # clickable action buttons — remember each one's row and column span for clicks
  bi="[ Install ${nsel} ]"; bu="[ Uninstall ]"; bb="[ Back ]"
  printf '\n'; row=$((row + 1))
  row=$((row + 1)); BTN_ROW=$row
  c=3
  BTN_I_LO=$c; BTN_I_HI=$((c + ${#bi} - 1)); c=$((BTN_I_HI + 4))
  BTN_U_LO=$c; BTN_U_HI=$((c + ${#bu} - 1)); c=$((BTN_U_HI + 4))
  BTN_B_LO=$c; BTN_B_HI=$((c + ${#bb} - 1))
  printf '  %s%s%s%s   %s%s%s   %s%s%s\n' \
    "$BOLD" "$GREEN" "$bi" "$RESET" "$RED" "$bu" "$RESET" "$DIM" "$bb" "$RESET"

  printf '\n  %s↑/↓%s move   %sspace/enter%s select   %sa%s all   %si%s install   %sx%s uninstall   %s←%s back\n' \
    "$BOLD" "$RESET" "$BOLD" "$RESET" "$BOLD" "$RESET" "$GREEN" "$RESET" "$RED" "$RESET" "$BOLD" "$RESET"
  [ -n "$TUI_MSG" ] && printf '  %s\n' "$TUI_MSG"
  return 0
}

# Wait for a genuine keypress after an action's output. Uses read_key so a whole
# escape/mouse sequence is consumed at once — leftover mouse-release bytes from the
# click that triggered the action are swallowed instead of dismissing the prompt or
# leaking in as stray keystrokes.
tui_pause() { # $1 = message
  printf '%s  %s%s' "$DIM" "${1:-Press any key to return ...}" "$RESET"
  while read_key; do
    case "$KEY" in mouse) : ;; *) break ;; esac
  done
}

# true if at least one bundle in the list is checkbox-selected
tui_any_selected() {
  local i
  for i in "${!NAMES[@]}"; do [ "${SEL[$i]}" = 1 ] && return 0; done
  return 1
}

# Mouse in the bundle list: scroll moves the cursor; a click opens the clicked
# bundle's skills (the natural "click a row to open it").
tui_mouse_bundles() {
  [ "$MOUSE_TYPE" = press ] || return 0
  local idx
  case "$MOUSE_BTN" in
    64) [ "$cursor" -gt 0 ] && cursor=$((cursor - 1)) ;;
    65) [ "$cursor" -lt $(( ${#NAMES[@]} - 1 )) ] && cursor=$((cursor + 1)) ;;
    *)
      idx="${CLICK_ITEM[$MOUSE_Y]:-}"
      if [ -n "$idx" ]; then
        cursor="$idx"
        CUR_BUNDLE="${NAMES[$idx]}"; icursor=0; VIEW=items; tui_load_items none
      fi
      ;;
  esac
  return 0
}

# Mouse in the skill picker: scroll moves the cursor; a click on a row toggles
# its checkbox; a click on an action button runs it.
tui_mouse_items() {
  [ "$MOUSE_TYPE" = press ] || return 0
  local idx
  case "$MOUSE_BTN" in
    64) [ "$icursor" -gt 0 ] && icursor=$((icursor - 1)) ;;
    65) [ "$icursor" -lt $(( ${#INAME[@]} - 1 )) ] && icursor=$((icursor + 1)) ;;
    *)
      if [ "$MOUSE_Y" -eq "$BTN_ROW" ]; then
        if   [ "$MOUSE_X" -ge "$BTN_I_LO" ] && [ "$MOUSE_X" -le "$BTN_I_HI" ]; then tui_run_item_action cmd_install
        elif [ "$MOUSE_X" -ge "$BTN_U_LO" ] && [ "$MOUSE_X" -le "$BTN_U_HI" ]; then tui_run_item_action cmd_uninstall
        elif [ "$MOUSE_X" -ge "$BTN_B_LO" ] && [ "$MOUSE_X" -le "$BTN_B_HI" ]; then VIEW=bundles; tui_load
        fi
      else
        idx="${CLICK_ITEM[$MOUSE_Y]:-}"
        if [ -n "$idx" ]; then
          icursor="$idx"
          if [ "${ISEL[$idx]}" = 1 ]; then ISEL[$idx]=0; else ISEL[$idx]=1; fi
        fi
      fi
      ;;
  esac
  return 0
}

# select-all / clear-all toggle
tui_toggle_all() {
  local i all=1
  for i in "${!NAMES[@]}"; do [ "${SEL[$i]}" = 1 ] || all=0; done
  for i in "${!NAMES[@]}"; do
    if [ "$all" = 1 ]; then SEL[$i]=0; else SEL[$i]=1; fi
  done
  return 0
}

tui_toggle_all_items() {
  local i all=1
  for i in "${!INAME[@]}"; do [ "${ISEL[$i]}" = 1 ] || all=0; done
  for i in "${!INAME[@]}"; do
    if [ "$all" = 1 ]; then ISEL[$i]=0; else ISEL[$i]=1; fi
  done
  return 0
}

# install / uninstall the selected items of $CUR_BUNDLE (or the one under the
# cursor if none are ticked) by handing "bundle:item,item" to the cmd_* function.
tui_run_item_action() { # $1 = command function name
  local fn="$1" i any=0 items=''
  for i in "${!INAME[@]}"; do
    if [ "${ISEL[$i]}" = 1 ]; then items="${items},${INAME[$i]}"; any=1; fi
  done
  [ "$any" = 1 ] || items=",${INAME[$icursor]}"
  items="${items#,}"
  [ -n "$items" ] || return 0
  BUNDLE_ARGS=("${CUR_BUNDLE}:${items}")
  if [ "$fn" = cmd_install ]; then
    tui_pick_target "Install selected items of ${CUR_BUNDLE} — where to?" \
      || { TUI_MSG="${TUI_MSG:-${DIM}install cancelled${RESET}}"; return 0; }
  fi
  if [ "$TUI_TARGET_MODE" = project ]; then OPT_PROJECT="$TUI_PROJECT_DIR"; else unset OPT_PROJECT 2>/dev/null || true; fi
  OPT_FORCE=0
  tui_mouse_off; printf '\033[?25h\033[H\033[2J'
  "$fn" || true
  tui_pause "Press any key to return ..."
  printf '\033[?25l'; tui_mouse_on
  tui_load_items
}

# run cmd_install / cmd_uninstall / cmd_update over the selected bundles (or, if
# none are selected, the one under the cursor), then reload status. Installing
# first asks where to put it; uninstall/update act on the current target.
tui_run_action() { # $1 = command function name
  local fn="$1" i any=0
  BUNDLE_ARGS=()
  for i in "${!NAMES[@]}"; do
    if [ "${SEL[$i]}" = 1 ]; then BUNDLE_ARGS[${#BUNDLE_ARGS[@]}]="${NAMES[$i]}"; any=1; fi
  done
  [ "$any" = 1 ] || BUNDLE_ARGS=("${NAMES[$cursor]}")
  if [ "$fn" = cmd_install ]; then
    tui_pick_target "Install ${#BUNDLE_ARGS[@]} bundle(s) — where to?" \
      || { TUI_MSG="${TUI_MSG:-${DIM}install cancelled${RESET}}"; return 0; }
  fi
  if [ "$TUI_TARGET_MODE" = project ]; then OPT_PROJECT="$TUI_PROJECT_DIR"; else unset OPT_PROJECT 2>/dev/null || true; fi
  OPT_FORCE=0
  tui_mouse_off; printf '\033[?25h\033[H\033[2J'
  "$fn" || true
  tui_pause "Press any key to return to the menu ..."
  printf '\033[?25l'; tui_mouse_on
  tui_load
}

# Prompt for a directory path (the only unavoidably-typed field). Sets $PATH_INPUT.
# Mouse reporting is turned off while the line is typed so clicks don't corrupt it.
tui_read_path() {
  PATH_INPUT=''
  tui_mouse_off
  printf '\033[H\033[2J\n  %sEnter a project directory%s  %s(the bundle installs into <path>/.claude — ~ is allowed)%s\n\n' \
    "$BOLD" "$RESET" "$DIM" "$RESET"
  printf '  %s›%s ' "$CYAN" "$RESET"
  printf '\033[?25h'
  IFS= read -r PATH_INPUT </dev/tty || PATH_INPUT=''
  printf '\033[?25l'
  tui_mouse_on
}

# Arrow-key + mouse target picker: user (~/.claude), the current directory, or a
# manual path. Sets TUI_TARGET_MODE/TUI_PROJECT_DIR and returns 0 on a choice;
# returns 1 if the user cancels (q/esc). $1 = heading shown above the options.
tui_pick_target() {
  local heading="${1:-Choose target}" sel nopts=3 perr='' i dir act optrow=4
  [ "$TUI_TARGET_MODE" = user ] && sel=0 || sel=1
  while :; do
    printf '\033[H\033[2J'
    printf '\n  %s%s%s\n\n' "$BOLD" "$heading" "$RESET"      # options begin at row 4
    for i in 0 1 2; do
      local lbl desc
      case "$i" in
        0) lbl='~/.claude'              ; desc='user — all projects' ;;
        1) lbl='./.claude'              ; desc="current dir: $PWD" ;;
        2) lbl='Enter a path manually…' ; desc='' ;;
      esac
      if [ "$sel" -eq "$i" ]; then
        printf '  %s❯%s %s%s%-24s%s  %s%s%s\n' "$CYAN" "$RESET" "$BOLD" "$CYAN" "$lbl" "$RESET" "$DIM" "$desc" "$RESET"
      else
        printf '    %-24s  %s%s%s\n' "$lbl" "$DIM" "$desc" "$RESET"
      fi
    done
    printf '\n  %s↑/↓%s move   %senter/click%s choose   %sesc/q%s cancel\n' \
      "$BOLD" "$RESET" "$BOLD" "$RESET" "$BOLD" "$RESET"
    [ -n "$perr" ] && printf '\n  %s\n' "$perr"
    read_key || return 1
    perr=''; act=0
    case "$KEY" in
      k|$'\033[A') sel=$(( (sel + nopts - 1) % nopts )) ;;
      j|$'\033[B') sel=$(( (sel + 1) % nopts )) ;;
      q|Q|$'\033') return 1 ;;
      ''|$'\r'|$'\n') act=1 ;;
      mouse)
        if [ "$MOUSE_TYPE" = press ]; then
          case "$MOUSE_BTN" in
            64) sel=$(( (sel + nopts - 1) % nopts )) ;;
            65) sel=$(( (sel + 1) % nopts )) ;;
            *) if [ "$MOUSE_Y" -ge "$optrow" ] && [ "$MOUSE_Y" -le "$((optrow + 2))" ]; then
                 sel=$(( MOUSE_Y - optrow )); act=1
               fi ;;
          esac
        fi
        ;;
    esac
    if [ "$act" = 1 ]; then
      case "$sel" in
        0) TUI_TARGET_MODE=user; return 0 ;;
        1) TUI_TARGET_MODE=project; TUI_PROJECT_DIR="$PWD"; return 0 ;;
        2)
          tui_read_path; dir="$PATH_INPUT"
          [ -n "$dir" ] || { perr="${YELLOW}no path entered — try again or press q${RESET}"; continue; }
          case "$dir" in
            '~')   dir="$HOME" ;;
            '~/'*) dir="${HOME}/${dir#\~/}" ;;
          esac
          if [ -d "$dir" ]; then
            TUI_TARGET_MODE=project; TUI_PROJECT_DIR="$(cd "$dir" && pwd)"; return 0
          fi
          perr="${RED}no such directory: ${dir}${RESET}"
          ;;
      esac
    fi
  done
}

# The `t` key: change the target the list is shown against (and the default for
# uninstall/update). Cancelling leaves the current target unchanged.
tui_change_target() {
  tui_pick_target "Change target" || true
  tui_load
}

# Launch the rich (Textual/Python) UI when a runtime for it exists. Returns 0 if
# it ran (however it exited), 1 if no runtime is available so the caller should
# fall back to the built-in pure-bash TUI. `claude-packs tui --basic` (or
# CLAUDE_PACKS_TUI=basic) skips the rich UI on purpose.
launch_rich_tui() {
  local script="${PKG_ROOT}/bin/claude-packs-tui.py" mode dir cli
  [ -f "$script" ] || return 1
  [ "${CLAUDE_PACKS_TUI:-}" = basic ] && return 1
  [ "$OPT_BASIC" -eq 1 ] && return 1
  if [ -n "${OPT_PROJECT+x}" ]; then mode=project; dir="${OPT_PROJECT:-$PWD}"; else mode=user; dir="$PWD"; fi
  cli="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
  # A PyPI install exports CLAUDE_PACKS_PYTHON (its venv ships Textual); otherwise
  # probe the system python3.
  local py="${CLAUDE_PACKS_PYTHON:-python3}"
  if command -v "$py" >/dev/null 2>&1 && "$py" -c 'import textual' 2>/dev/null; then
    CLAUDE_PACKS_ROOT="$PKG_ROOT" CLAUDE_PACKS_CLI="$cli" CLAUDE_PACKS_VERSION="$CLI_VERSION" \
    CLAUDE_PACKS_TARGET_MODE="$mode" CLAUDE_PACKS_PROJECT_DIR="$dir" \
      "$py" "$script" && return 0
    warn "the rich UI exited with an error — falling back to the basic menu."
    return 1
  fi
  if command -v uv >/dev/null 2>&1; then
    # uv reads the script's inline metadata and provisions Textual itself
    # (downloads once, then cached — subsequent launches are instant).
    CLAUDE_PACKS_ROOT="$PKG_ROOT" CLAUDE_PACKS_CLI="$cli" CLAUDE_PACKS_VERSION="$CLI_VERSION" \
    CLAUDE_PACKS_TARGET_MODE="$mode" CLAUDE_PACKS_PROJECT_DIR="$dir" \
      uv run --quiet --script "$script" && return 0
    warn "the rich UI could not start (uv run failed) — falling back to the basic menu."
    return 1
  fi
  return 1
}

cmd_tui() {
  [ -e /dev/tty ] || die "the interactive menu needs a terminal (no /dev/tty available).
Use the non-interactive commands instead, e.g. \"claude-packs list\"."
  [ -n "$(list_bundle_names)" ] || { say "No bundles found in ${BUNDLES_DIR}."; return 0; }

  launch_rich_tui && return 0

  # honor an initial --project/--user flag as the starting target; `t` changes it later
  if [ -n "${OPT_PROJECT+x}" ]; then
    TUI_TARGET_MODE=project
    TUI_PROJECT_DIR="${OPT_PROJECT:-$PWD}"
    [ -d "$TUI_PROJECT_DIR" ] || TUI_PROJECT_DIR="$PWD"
  else
    TUI_TARGET_MODE=user
    TUI_PROJECT_DIR="$PWD"
  fi
  TUI_MSG=''
  cursor=0
  icursor=0
  VIEW=bundles
  CUR_BUNDLE=''
  MOUSE_X=0; MOUSE_Y=0; MOUSE_BTN=0; MOUSE_TYPE=''
  BTN_ROW=0; BTN_I_LO=0; BTN_I_HI=0; BTN_U_LO=0; BTN_U_HI=0; BTN_B_LO=0; BTN_B_HI=0
  NAMES=(); VERS=(); TITLES=(); INST=(); SEL=(); NINST=(); NTOTAL=(); CLICK_ITEM=()
  IKIND=(); INAME=(); IINST=(); ISEL=()

  trap 'tui_leave_screen' EXIT INT TERM
  tui_enter_screen
  tui_load

  local n
  while :; do
    if [ "$VIEW" = items ]; then tui_draw_items; else tui_draw; fi
    read_key || break
    TUI_MSG=''
    if [ "$VIEW" = items ]; then
      n=${#INAME[@]}
      case "$KEY" in
        k|$'\033[A') if [ "$icursor" -gt 0 ]; then icursor=$((icursor - 1)); else icursor=$((n - 1)); fi ;;
        j|$'\033[B') if [ "$icursor" -lt $((n - 1)) ]; then icursor=$((icursor + 1)); else icursor=0; fi ;;
        # space AND enter both toggle the focused item's checkbox
        ' '|''|$'\r'|$'\n') if [ "${ISEL[$icursor]}" = 1 ]; then ISEL[$icursor]=0; else ISEL[$icursor]=1; fi ;;
        a|A) tui_toggle_all_items ;;
        i|I) tui_run_item_action cmd_install ;;
        x|X|d|D) tui_run_item_action cmd_uninstall ;;
        h|$'\033[D'|q|Q|$'\033') VIEW=bundles; tui_load ;;
        mouse) tui_mouse_items ;;
      esac
    else
      n=${#NAMES[@]}
      case "$KEY" in
        k|$'\033[A') if [ "$cursor" -gt 0 ]; then cursor=$((cursor - 1)); else cursor=$((n - 1)); fi ;;
        j|$'\033[B') if [ "$cursor" -lt $((n - 1)) ]; then cursor=$((cursor + 1)); else cursor=0; fi ;;
        # space AND enter both toggle the focused bundle's checkbox
        ' '|''|$'\r'|$'\n') if [ "${SEL[$cursor]}" = 1 ]; then SEL[$cursor]=0; else SEL[$cursor]=1; fi ;;
        a|A) tui_toggle_all ;;
        i|I)
          # multiple bundles ticked → install them whole; otherwise open the
          # skill picker for the bundle under the cursor (all pre-ticked)
          if tui_any_selected; then
            tui_run_action cmd_install
          else
            CUR_BUNDLE="${NAMES[$cursor]}"; icursor=0; VIEW=items; tui_load_items all
          fi
          ;;
        x|X|d|D) tui_run_action cmd_uninstall ;;
        u|U) tui_run_action cmd_update ;;
        t|T) tui_change_target ;;
        r|R) tui_load; TUI_MSG="${DIM}refreshed${RESET}" ;;
        l|$'\033[C')            # →  open the bundle's skills (browse / pick)
          CUR_BUNDLE="${NAMES[$cursor]}"; icursor=0; VIEW=items; tui_load_items none ;;
        q|Q|$'\033') break ;;
        mouse) tui_mouse_bundles ;;
      esac
    fi
  done

  tui_leave_screen
  trap - EXIT INT TERM
}

help_for() { # $1=command -> detailed per-command help
  case "$1" in
    tui|ui|menu) cat <<EOF

${BOLD}claude-packs tui${RESET} — interactive full-screen menu

Two implementations, picked automatically:

  ${BOLD}rich UI${RESET}   a real windowed-feel interface (buttons, checkboxes, dialogs,
            toasts, scrollbars, full mouse support). Used when Python with
            ${CYAN}Textual${RESET} is available — or ${CYAN}uv${RESET}, which sets it up on first run.
  ${BOLD}basic UI${RESET}  the built-in pure-bash menu — zero dependencies, same features.
            Used as the fallback, or on request: ${CYAN}claude-packs tui --basic${RESET}
            (or CLAUDE_PACKS_TUI=basic).

Drive it with the keyboard or the mouse — no commands or paths to memorize.
${BOLD}Click${RESET} a bundle to open it, ${BOLD}click${RESET} skills to tick them, ${BOLD}click${RESET} a button or target, and
${BOLD}scroll${RESET} to move. Everything also works from the keyboard.

The flow: open a bundle (→ or a click) to see its skills and agents, ${BOLD}select${RESET} the
ones you want (space, enter, or a click; ${BOLD}a${RESET} = all), then ${BOLD}i${RESET} — or the ${BOLD}[ Install ]${RESET}
button — to install them. Pressing ${BOLD}i${RESET} on a bundle in the list opens the same picker
with everything pre-ticked, so a whole-bundle install is just ${BOLD}i${RESET} then ${BOLD}i${RESET}. Every
install ends with a ${BOLD}target picker${RESET}: ${BOLD}~/.claude${RESET} (user, all projects), the ${BOLD}current
directory${RESET}, or a ${BOLD}path you type in${RESET}.

The ${BOLD}t${RESET} key sets the target the list is shown against (and the default for
uninstall/update). Partly-installed bundles show ${YELLOW}◑ partial (n/total)${RESET}. Running
${CYAN}claude-packs${RESET} with no command on a terminal opens this menu.

${BOLD}Bundle list${RESET}
  ↑/↓ k/j scroll   move         space/enter/click   select      → or click   open bundle
  i   install      x uninstall  u update            t target    r refresh     q quit

${BOLD}Skill picker${RESET} (inside a bundle)
  ↑/↓ k/j scroll   move         space/enter/click   select      a   all
  i or [Install]   install      x uninstall         ← or q   back

${BOLD}Target picker${RESET} (shown when you install)
  ↑/↓ scroll  move      enter or click  choose      esc or q  cancel

${BOLD}Usage${RESET}
  claude-packs tui
EOF
      ;;
    list|ls) cat <<EOF

${BOLD}claude-packs list${RESET} — list available bundles and their install status

Shows every bundle in the registry with its version, contents summary, and whether
it is installed at the target — flagging installs that are behind
(${GREEN}✓ installed${RESET}${DIM} (1.1.0 → 1.2.0 available)${RESET}).

${BOLD}Usage${RESET}
  claude-packs list [--user | --project [dir]]
EOF
      ;;
    info|show) cat <<EOF

${BOLD}claude-packs info <bundle>${RESET} — show a bundle's details

Prints the bundle's description, tags, guide location, and the exact skills and
agents it installs.

${BOLD}Usage${RESET}
  claude-packs info aws-connect
EOF
      ;;
    install|add) cat <<EOF

${BOLD}claude-packs install <bundle[:item,...]...>${RESET} — install bundles or specific items

Copies the bundle's skills into <target>/skills and agents into <target>/agents,
and records them in a receipt (${RESET}${DIM}<target>/.claude-packs${RESET}) so update/uninstall know
what this tool owns. Files that exist but are NOT tracked by the receipt prompt
before being overwritten (skip with --force).

Append ${BOLD}:item,item${RESET} to install just those skills/agents instead of the whole
bundle. Selective installs are additive — installing more items later keeps the
ones already there — and ${CYAN}update${RESET} refreshes only your selection rather than
re-expanding it to the full bundle. (The interactive ${CYAN}tui${RESET} does the same via a
point-and-select item view.)

${BOLD}Usage${RESET}
  claude-packs install <bundle[:item,...]...> [--user | --project [dir]] [--force]

${BOLD}Examples${RESET}
  claude-packs install aws-connect                              # whole bundle → ~/.claude
  claude-packs install aws-connect --project .                 # whole bundle → ./.claude
  claude-packs install aws-connect:aws-connect-build           # one skill only
  claude-packs install aws-connect:aws-connect-verify,aws-connect-architect

Restart Claude Code afterwards — skills and agents load at session start.
EOF
      ;;
    uninstall|remove|rm) cat <<EOF

${BOLD}claude-packs uninstall <bundle[:item,...]...>${RESET} — remove bundles or specific items

Removes only the skills/agents the receipt says this tool installed; anything you
added yourself is left alone. Append ${BOLD}:item,item${RESET} to remove just those items and
leave the rest of the bundle in place (removing the last item drops the bundle).

${BOLD}Usage${RESET}
  claude-packs uninstall <bundle[:item,...]...> [--user | --project [dir]]

${BOLD}Examples${RESET}
  claude-packs uninstall aws-connect                    # remove the whole bundle
  claude-packs uninstall aws-connect:aws-connect-build  # remove one item only
EOF
      ;;
    update|upgrade) cat <<EOF

${BOLD}claude-packs update [bundle...]${RESET} — upgrade installed bundles to the latest

With no arguments, updates every bundle installed at the target. For a managed
git-backed install it refreshes the registry first (git pull), then re-copies the
latest bundle content over the install, prunes skills/agents a newer bundle
version no longer ships, and prints each version transition.

Whole-bundle installs pick up any newly-shipped items; a selective install
(installed with ${BOLD}bundle:item${RESET} or via the tui item view) is refreshed in place and
stays a selection — update never silently re-expands it to the full bundle.

Also effectively updates the CLI: the registry pull brings the newest
bin/claude-packs along with the bundles.

${BOLD}Usage${RESET}
  claude-packs update [bundle...] [--user | --project [dir]]

${DIM}Upgrading from a CLI older than v1.2.0? Run "claude-packs self-update" once
first — older CLIs don't refresh the registry on update.${RESET}
EOF
      ;;
    installed) cat <<EOF

${BOLD}claude-packs installed${RESET} — list what is installed at the target

Reads the install receipt and prints each bundle with its version and item counts.

${BOLD}Usage${RESET}
  claude-packs installed [--user | --project [dir]]
EOF
      ;;
    self-update) cat <<EOF

${BOLD}claude-packs self-update${RESET} — update the CLI + registry itself

Git-backed installs: git pull in the registry (${RESET}${DIM}${PKG_ROOT}${RESET}) — this updates the
claude-packs CLI and all bundle content in one step. Installs made with
"install.sh --local" have no git history; self-update offers to re-run the
installer, which switches them to a git-backed install.

Follow with ${CYAN}claude-packs update${RESET} to push the newer bundle content into your
installed targets.

${BOLD}Usage${RESET}
  claude-packs self-update [--force]
EOF
      ;;
    self-uninstall) cat <<EOF

${BOLD}claude-packs self-uninstall${RESET} — remove the CLI from this device

Deletes the managed registry and the launcher on your PATH. Bundles already
installed into projects or ~/.claude are NOT touched — remove those first with
"claude-packs uninstall".

${BOLD}Usage${RESET}
  claude-packs self-uninstall [--force]
EOF
      ;;
    help) cat <<EOF

${BOLD}claude-packs help [command]${RESET} — show help

Without a command, prints the global usage. With one, prints that command's
detailed help (same as ${CYAN}claude-packs <command> --help${RESET}).
EOF
      ;;
    *)
      warn "no such command \"$1\""
      usage
      return 1
      ;;
  esac
  printf '\n'
}

usage() {
  cat <<EOF

${BOLD}claude-packs${RESET} ${DIM}v${CLI_VERSION}${RESET} — install Claude Code skill/agent bundles

${BOLD}Usage${RESET}
  claude-packs <command> [bundles...] [options]

${BOLD}Commands${RESET}
  ${CYAN}tui${RESET}                        interactive menu to browse and manage bundles
  ${CYAN}list${RESET}                       list available bundles and install status
  ${CYAN}info${RESET} <bundle>              show a bundle's skills, agents, and description
  ${CYAN}install${RESET} <bundle[:item,...]> install a bundle, or just specific skills/agents
  ${CYAN}uninstall${RESET} <bundle[:item,...]> remove a bundle, or just specific items
  ${CYAN}update${RESET} [bundle...]         refresh the registry + upgrade installs to latest
  ${CYAN}installed${RESET}                  list bundles installed at the target
  ${CYAN}self-update${RESET}                update the claude-packs CLI + registry itself
  ${CYAN}self-uninstall${RESET}             remove the claude-packs CLI from this device
  ${CYAN}help${RESET} [command]             detailed help for a command (or: <command> --help)

${BOLD}Options${RESET}
  -u, --user                 install into ~/.claude  ${DIM}(default; all projects)${RESET}
  -p, --project [dir]        install into <dir>/.claude  ${DIM}(default dir: cwd)${RESET}
  -f, --force                overwrite without prompting
  -b, --basic                tui: use the built-in bash menu, skip the rich UI
  -h, --help                 show this help
  -V, --version              print version

${BOLD}Examples${RESET}
  claude-packs                                  # open the interactive menu
  claude-packs tui
  claude-packs list
  claude-packs install aws-connect --user
  claude-packs install aws-connect --project .
  claude-packs install aws-connect:aws-connect-build   # just one skill
  claude-packs uninstall aws-connect --project ~/my-app
  claude-packs self-update

${DIM}registry: ${PKG_ROOT}${RESET}
EOF
}

# --- arg parsing ----------------------------------------------------------------
OPT_FORCE=0
OPT_HELP=0
OPT_BASIC=0
BUNDLE_ARGS=()
COMMAND=''

while [ $# -gt 0 ]; do
  case "$1" in
    -u|--user) unset OPT_PROJECT 2>/dev/null || true; shift ;;
    -p|--project)
      shift
      if [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; then OPT_PROJECT="$1"; shift; else OPT_PROJECT=""; fi
      ;;
    -f|--force) OPT_FORCE=1; shift ;;
    -b|--basic) OPT_BASIC=1; shift ;;
    -h|--help) OPT_HELP=1; shift ;;
    -V|--version) printf '%s\n' "$CLI_VERSION"; exit 0 ;;
    -*) die "unknown option: $1 (see --help)" ;;
    *)
      if [ -z "$COMMAND" ]; then COMMAND="$1"; else BUNDLE_ARGS[${#BUNDLE_ARGS[@]}]="$1"; fi
      shift
      ;;
  esac
done

# `claude-packs <command> --help` → that command's help; bare --help → global usage
if [ "$OPT_HELP" -eq 1 ]; then
  if [ -n "$COMMAND" ] && [ "$COMMAND" != "help" ]; then help_for "$COMMAND"; else usage; fi
  exit $?
fi

# Bare invocation on a terminal opens the interactive menu; otherwise print usage
# (keeps piped/non-interactive `claude-packs` behaving as documentation).
if [ -z "$COMMAND" ]; then
  if [ -t 1 ] && [ -e /dev/tty ]; then cmd_tui; exit $?; else usage; exit 0; fi
fi

case "$COMMAND" in
  help)
    if [ "${#BUNDLE_ARGS[@]}" -gt 0 ]; then help_for "${BUNDLE_ARGS[0]}"; else usage; fi
    ;;
  tui|ui|menu)         cmd_tui ;;
  list|ls)             cmd_list ;;
  info|show)           cmd_info ;;
  install|add)         cmd_install ;;
  uninstall|remove|rm) cmd_uninstall ;;
  update|upgrade)      cmd_update ;;
  installed)           cmd_installed ;;
  self-update)         cmd_self_update ;;
  self-uninstall)      cmd_self_uninstall ;;
  *) die "unknown command \"$COMMAND\". Run \"claude-packs --help\"." ;;
esac
